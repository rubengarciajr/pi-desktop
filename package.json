{
  "name": "pi-desktop",
  "version": "0.6.0",
  "description": "Pi Desktop - a full-featured macOS desktop app for the Pi coding agent",
  "main": "out/main/index.js",
  "author": "Pi Desktop",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build:mac": "electron-vite build && node build/package-dmg.cjs --mac",
    "build:dmg": "electron-vite build && node build/package-dmg.cjs --mac dmg",
    "package": "electron-vite build && node build/package-dmg.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@esbuild/darwin-arm64": "^0.28.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.10",
    "remark-gfm": "^4.0.1",
    "undici": "^8.5.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^41.10.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
